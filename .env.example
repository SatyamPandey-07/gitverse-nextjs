# Environment variables template
# Copy this file to .env.local and fill in your values

# Database
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST/neondb?sslmode=require&schema=public

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# NextAuth Secret (required for NextAuth.js)
NEXTAUTH_SECRET=your-nextauth-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini AI API Key (for AI Assistant features)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: For client-side API calls
NEXT_PUBLIC_API_URL=http://localhost:3000
